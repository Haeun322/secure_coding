# 아래 값을 복사해 .env 파일을 만들고 실제 값으로 채운 뒤 사용합니다.
# .env 파일은 절대 커밋하지 않습니다 (.gitignore 에 등록되어 있음).

# 세션/CSRF 서명에 사용하는 비밀키. 반드시 무작위 값으로 교체할 것.
# 생성 예시:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-hex-string

# 운영(HTTPS) 환경이면 1, 로컬 개발이면 0.
# 1이면 세션 쿠키에 Secure 플래그가 붙어 HTTPS 에서만 전송됩니다.
SESSION_COOKIE_SECURE=0

# 최초 실행 시 자동으로 만들어질 관리자 계정 정보.
# 계정 생성 후에는 이 변수를 지워도 됩니다.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisAdminPw!234
